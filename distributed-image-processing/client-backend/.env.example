# Backend Intermedio - Configuración

# Puerto donde escucha el backend
BACKEND_PORT=3001

# URL del App-Server JAVA (donde está el SOAP)
JAVA_APP_SERVER_URL=http://localhost:8080

# URL base para callbacks (cuando worker-nodes notifican)
CALLBACK_BASE_URL=http://localhost:3001

# Directorio para archivos cargados temporalmente
UPLOAD_DIR=./uploads

# Información de logging
LOG_LEVEL=info
